# ============================================================
# Thekedar AI — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to git.
# ============================================================

# ------------------------------------------------------------
# Auth — Contractor credentials
# Option A (recommended): Individual slots for up to 10 contractors
# Option B: JSON array (see below)
# ------------------------------------------------------------

C1_USERNAME=contractor1
C1_PASSWORD=changeme123
C1_ID=c1

C2_USERNAME=contractor2
C2_PASSWORD=changeme456
C2_ID=c2

# Option B (uncomment to use instead of individual slots):
# CONTRACTORS_JSON=[{"id":"c1","username":"contractor1","passwordHash":"sha256-hex-of-password"},{"id":"c2","username":"contractor2","passwordHash":"sha256-hex-of-password"}]

# JWT signing secret — set a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret

# ------------------------------------------------------------
# xAI (Grok) — required for AI Chat feature
# Get your key at: https://console.x.ai
# ------------------------------------------------------------
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-3-mini

# ------------------------------------------------------------
# Server port (local dev only)
# ------------------------------------------------------------
PORT=8787

# ------------------------------------------------------------
# Vercel KV (Upstash Redis) — required only for Vercel deployment
# These are auto-set by Vercel when you connect a KV store.
# Leave blank for local development (file-based storage is used).
# ------------------------------------------------------------
KV_REST_API_URL=
KV_REST_API_TOKEN=
