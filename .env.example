# ============================================================
# Thekedar AI — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to git.
# ============================================================

# ------------------------------------------------------------
# Server port (local dev only)
# ------------------------------------------------------------
PORT=8787

# ------------------------------------------------------------
# Groq API — required for AI Chat feature
# Get your key at: https://console.groq.com
# ------------------------------------------------------------
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ------------------------------------------------------------
# Auth — Contractor credentials
# Each contractor can login via username/password OR PIN
# C{i}_PIN is a 4-digit PIN for mobile login
# C{i}_LABEL is the display name for that contractor
# ------------------------------------------------------------

# Contractor 1
C1_USERNAME=rajesh
C1_PASSWORD=your_password_here
C1_PIN=1234
C1_ID=contractor1
C1_LABEL=Rajesh Contractors

# Contractor 2
C2_USERNAME=sunil
C2_PASSWORD=your_password_here
C2_PIN=5678
C2_ID=contractor2
C2_LABEL=Sunil Labour Supply

# Option B — JSON array (uncomment to use instead of individual slots):
# CONTRACTORS_JSON=[{"id":"c1","username":"rajesh","passwordHash":"sha256-hex","pin":"1234","label":"Rajesh Contractors"},{"id":"c2","username":"sunil","passwordHash":"sha256-hex","pin":"5678","label":"Sunil Labour Supply"}]

# JWT signing secret — set a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret

# ------------------------------------------------------------
# Vercel KV (Upstash Redis) — required only for Vercel deployment
# These are auto-set by Vercel when you connect a KV store.
# Leave blank for local development (file-based storage is used).
# ------------------------------------------------------------
KV_REST_API_URL=
KV_REST_API_TOKEN=
